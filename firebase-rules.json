{
  "rules": {
    "events": {
      ".read": "auth != null",
      "$eventId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
        ".validate": "newData.hasChildren(['locationId','type','userId','ts']) && newData.child('userId').val() === auth.uid && newData.child('ts').val() <= now && newData.child('ts').val() >= now - 5000"
      },
      ".indexOn": ["ts", "locationId"]
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid",
        ".validate": "newData.hasChildren(['name'])"
      }
    },
    "comments": {
      "$locId": {
        ".read": "auth != null",
        "$commentId": {
          ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
          ".validate": "newData.hasChildren(['text','userId','userName','ts']) && newData.child('userId').val() === auth.uid && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 200 && newData.child('ts').val() <= now"
        },
        ".indexOn": ["ts"]
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    },
    "places": {
      ".read": "auth != null",
      "$placeId": {
        ".write": "auth != null && (!data.exists() || data.child('ownerId').val() === auth.uid)"
      }
    },
    "rateLimit": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "chats": {
      "$locId": {
        ".read": "auth != null",
        "$msgId": {
          ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid)",
          ".validate": "newData.hasChildren(['text','userId','ts']) && newData.child('userId').val() === auth.uid && newData.child('text').val().length >= 1 && newData.child('text').val().length <= 500"
        },
        ".indexOn": ["ts"]
      }
    },
    "going": {
      "$locId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth.uid === $uid"
        }
      }
    }
  }
}
